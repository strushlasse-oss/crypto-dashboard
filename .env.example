# Claude AI narrative (ai overview + market mood + market policy)
# If not set, the app falls back to deterministic text using edge-factor data.
ANTHROPIC_API_KEY=

# CryptoPanic news feed (free tier token at https://cryptopanic.com/developers/api/)
# If not set, news card falls back to static placeholders.
CRYPTOPANIC_TOKEN=

# Telegram MTProto (WatcherGuru realtime feed)
# Obtain api_id/hash at https://my.telegram.org, then export session via gramjs.
TG_API_ID=
TG_API_HASH=
TG_SESSION_STRING=

# No-auth providers: CoinGecko, alternative.me F&G, Yahoo BTC=F, ForexFactory, Binance futures.
